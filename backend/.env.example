NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string (create free cluster at cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/freight_erp?retryWrites=true&w=majority

# Set this to your Vercel frontend URL after deploying
CORS_ORIGIN=https://your-app.vercel.app

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-strong-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads

# OCR
OCR_ENGINE=tesseract

# Email (set to smtp and fill SMTP_* to send real emails)
EMAIL_PROVIDER=console
EMAIL_FROM_NAME=Freight ERP
EMAIL_FROM_ADDRESS=noreply@your-domain.com

# SMTP (only used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Branding (used in PDF + email templates)
BRAND_NAME=Freight ERP
BRAND_ADDRESS=123 Logistics Avenue, Karachi, Pakistan
BRAND_EMAIL=hello@your-domain.com
BRAND_PHONE=+92 21 1234 5678
BRAND_WEBSITE=www.your-domain.com
BRAND_COLOR=#0b5ed7
